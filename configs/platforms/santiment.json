{
  "siteName": "Santiment",
  "platformKey": "santiment",
  "matchRules": [
    {
      "pageType": "chart_page",
      "urlPatterns": [
        "^https://app\\.santiment\\.net/charts/social-dominance-bitcoin-23193/?$"
      ]
    }
  ],
  "viewports": {
    "default": {
      "width": 1600,
      "height": 1400,
      "deviceScaleFactor": 1
    }
  },
  "waitConditions": {
    "networkIdleMs": 1500,
    "extraDelayMs": 5000,
    "requiredSelectors": [
      "div.widget.column.svelte-veo1tu",
      "body"
    ]
  },
  "captures": [
    {
      "captureKey": "social_dominance_chart",
      "pageType": "chart_page",
      "strategy": "element_or_crop",
      "selectors": [
        "div.widget.column.svelte-veo1tu"
      ],
      "fallbackSelectors": [
        "body"
      ],
      "cropRules": {
        "anchorSelector": "body",
        "x": 180,
        "y": 220,
        "width": 1240,
        "height": 760
      },
      "scrollIntoView": true,
      "retries": 2
    }
  ],
  "output": {
    "fileTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.png",
    "metadataTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.json"
  }
}
