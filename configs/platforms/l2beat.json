{
  "siteName": "L2BEAT",
  "platformKey": "l2beat",
  "matchRules": [
    {
      "pageType": "scaling_project_page",
      "urlPatterns": [
        "^https://l2beat\\.com/scaling/projects/[a-z0-9-]+/?$"
      ]
    }
  ],
  "viewports": {
    "default": {
      "width": 1600,
      "height": 1400,
      "deviceScaleFactor": 1
    }
  },
  "waitConditions": {
    "networkIdleMs": 1500,
    "extraDelayMs": 4000,
    "requiredSelectors": [
      "div.mt-4.mb-3",
      "body"
    ]
  },
  "captures": [
    {
      "captureKey": "project_primary_card",
      "pageType": "scaling_project_page",
      "strategy": "element_or_crop",
      "selectors": [
        "div.mt-4.mb-3"
      ],
      "fallbackSelectors": [
        "body"
      ],
      "cropRules": {
        "anchorSelector": "body",
        "x": 200,
        "y": 180,
        "width": 1200,
        "height": 760
      },
      "scrollIntoView": true,
      "retries": 2
    }
  ],
  "output": {
    "fileTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.png",
    "metadataTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.json"
  }
}
