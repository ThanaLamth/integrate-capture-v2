{
  "siteName": "Dune",
  "platformKey": "dune",
  "matchRules": [
    {
      "pageType": "collection_page",
      "urlPatterns": [
        "^https://dune\\.com/collection/[a-z0-9-]+/[a-z0-9-]+/?$"
      ]
    }
  ],
  "viewports": {
    "default": {
      "width": 1600,
      "height": 1400,
      "deviceScaleFactor": 1
    }
  },
  "waitConditions": {
    "networkIdleMs": 1500,
    "extraDelayMs": 5000,
    "requiredSelectors": [
      "div.px-8.pt-8.pr-8.pb-12",
      "body"
    ]
  },
  "captures": [
    {
      "captureKey": "collection_overview_card",
      "pageType": "collection_page",
      "strategy": "element_or_crop",
      "selectors": [
        "div.px-8.pt-8.pr-8.pb-12"
      ],
      "fallbackSelectors": [
        "body"
      ],
      "cropRules": {
        "anchorSelector": "body",
        "x": 180,
        "y": 180,
        "width": 1240,
        "height": 760
      },
      "scrollIntoView": true,
      "retries": 2
    }
  ],
  "output": {
    "fileTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.png",
    "metadataTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.json"
  }
}
