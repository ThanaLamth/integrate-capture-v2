{
  "siteName": "CoinMarketCap",
  "platformKey": "coinmarketcap",
  "matchRules": [
    {
      "pageType": "coin_detail",
      "urlPatterns": [
        "^https://coinmarketcap\\.com/currencies/(?<slug>[a-z0-9-]+)/?$"
      ]
    }
  ],
  "viewports": {
    "default": {
      "width": 1440,
      "height": 2200,
      "deviceScaleFactor": 1
    }
  },
  "waitConditions": {
    "networkIdleMs": 1500,
    "extraDelayMs": 2500,
    "requiredSelectors": [
      "#section-coin-chart > div > div > div > div.sc-802a3cad-1.iFjImj > div",
      "/html/body/div[1]/div[2]/div/div[2]/div/div/div[3]"
    ]
  },
  "captures": [
    {
      "captureKey": "price_chart",
      "pageType": "coin_detail",
      "strategy": "element_or_crop",
      "selectors": [
        "#section-coin-chart > div > div > div > div.sc-802a3cad-1.iFjImj > div",
        "/html/body/div[1]/div[2]/div/div[2]/div/div/div[3]"
      ],
      "fallbackSelectors": [
        "main",
        "body"
      ],
      "cropRules": {
        "anchorSelector": "main",
        "x": 80,
        "y": 320,
        "width": 1180,
        "height": 620
      },
      "scrollIntoView": true,
      "retries": 2
    }
  ],
  "output": {
    "fileTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.png",
    "metadataTemplate": "{site_id}__{asset_slug}__{platform_key}__{capture_key}__{timestamp}.json"
  }
}
